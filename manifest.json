{
  "manifest_version": 1,
  "slug": "lore-os",
  "name": "Lore OS",
  "version": "0.1.10",
  "description": "Opinionated behavioral layer for the Lore harness. Guards, nudges, ambiguity scanning, and a structured knowledge system.",
  "hooks": {
    "pre-tool-use": [
      { "name": "Memory Guard", "script": "SCRIPTS/memory-guard.mjs" },
      { "name": "Auto-Memory Redirect", "script": "SCRIPTS/auto-memory-redirect.mjs" },
      { "name": "Harness Guard", "script": "SCRIPTS/harness-guard.mjs" },
      { "name": "Search Nudge", "script": "SCRIPTS/search-nudge.mjs" }
    ],
    "post-tool-use": [
      { "name": "Memory Capture", "script": "SCRIPTS/memory-capture.mjs" }
    ],
    "prompt-submit": [
      { "name": "Ambiguity Nudge", "script": "SCRIPTS/ambiguity-nudge.mjs" }
    ]
  },
  "tui": {
    "pages": [
      {
        "name": "Memory",
        "script": "SCRIPTS/tui-memory.mjs"
      }
    ]
  },
  "setup": "SCRIPTS/setup.mjs",
  "teardown": "SCRIPTS/teardown.mjs"
}
